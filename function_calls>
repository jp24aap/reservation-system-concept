<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Page Not Found - Sweet Dreams Maid Café</title>
    <link rel="stylesheet" href="styles.css">
    <script src="database.js"></script>
</head>
<body>
    <!-- Fake 404 page -->
    <div id="fake404" class="error-page">
        <div class="error-container">
            <h1>404</h1>
            <h2>Page Not Found</h2>
            <p>Oops! The page you are looking for doesn't exist.</p>
            <a href="index.html" class="home-link">Return to Home</a>
        </div>
    </div>

    <!-- Login screen (hidden initially) -->
    <div id="loginScreen" class="login-screen" style="display: none;">
        <div class="login-container">
            <h1>✧ Admin Login ✧</h1>
            <div class="login-form">
                <input type="password" id="adminPassword" placeholder="Enter admin password">
                <button onclick="checkPassword()">Login</button>
                <p id="loginError" class="error-message"></p>
            </div>
        </div>
    </div>

    <!-- Admin panel (hidden initially) -->
    <div id="adminPanel" class="admin-panel" style="display: none;">
        // ... existing code ...
    </div>

    <script>
        // Admin password - change this to your preferred password
        const ADMIN_PASSWORD = "maidcafe2023";
        
        // Secret key combination to reveal login
        document.addEventListener('keydown', function(e) {
            // Secret key combination: Ctrl + Alt + M
            if (e.ctrlKey && e.altKey && e.key === 'm') {
                document.getElementById('fake404').style.display = 'none';
                document.getElementById('loginScreen').style.display = 'flex';
            }
        });
        
        // Check if already logged in
        function checkLoggedIn() {
            const isLoggedIn = sessionStorage.getItem('adminLoggedIn');
            if (isLoggedIn === 'true') {
                document.getElementById('fake404').style.display = 'none';
                document.getElementById('loginScreen').style.display = 'none';
                document.getElementById('adminPanel').style.display = 'block';
                // Initialize data display
                displayReservations();
                displayOrders();
            }
        }
        
        // Check password
        function checkPassword() {
            const password = document.getElementById('adminPassword').value;
            if (password === ADMIN_PASSWORD) {
                // Store login state in session storage
                sessionStorage.setItem('adminLoggedIn', 'true');
                document.getElementById('loginScreen').style.display = 'none';
                document.getElementById('adminPanel').style.display = 'block';
                // Initialize data display
                displayReservations();
                displayOrders();
            } else {
                document.getElementById('loginError').textContent = 'Incorrect password';
            }
        }
        
        // Logout function
        function logout() {
            sessionStorage.removeItem('adminLoggedIn');
            // Show the fake 404 page instead of login screen when logging out
            document.getElementById('fake404').style.display = 'flex';
            document.getElementById('adminPanel').style.display = 'none';
            document.getElementById('loginScreen').style.display = 'none';
            document.getElementById('adminPassword').value = '';
            document.getElementById('loginError').textContent = '';
        }
        
        // Initialize database manager
        const db = new DatabaseManager();
        
        // ... rest of your existing JavaScript functions ...
        
        // Check login status when page loads
        window.onload = checkLoggedIn;
    </script>
    
    <style>
        /* Fake 404 page styles */
        .error-page {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: #f8f9fa;
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 1000;
            text-align: center;
        }
        
        .error-container {
            max-width: 500px;
            padding: 40px;
        }
        
        .error-page h1 {
            font-size: 120px;
            margin: 0;
            color: #ff6b81;
        }
        
        .error-page h2 {
            font-size: 28px;
            margin: 0 0 20px;
            color: #333;
        }
        
        .error-page p {
            font-size: 18px;
            margin-bottom: 30px;
            color: #555;
        }
        
        .home-link {
            display: inline-block;
            padding: 12px 25px;
            background: var(--primary-color);
            color: white;
            text-decoration: none;
            border-radius: 25px;
            font-weight: bold;
            transition: all 0.3s;
        }
        
        .home-link:hover {
            transform: translateY(-3px);
            box-shadow: 0 4px 10px rgba(255, 107, 129, 0.3);
        }
        
        /* Login screen styles */
        .login-screen {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(255, 245, 248, 0.9);
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 1000;
        }
        
        // ... rest of your existing CSS ...
    </style>
</body>
</html> 